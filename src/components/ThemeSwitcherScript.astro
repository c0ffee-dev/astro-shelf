<Fragment>
    <script is:inline>
        const getTheme = () => {
            const saved = localStorage.getItem("theme");
            if (saved) return saved;
            return "system";
        };

        const applyTheme = (theme) => {
            const isDark =
                theme === "dark" ||
                (theme === "system" &&
                    window.matchMedia("(prefers-color-scheme: dark)").matches);

            document.documentElement.classList.toggle("dark", isDark);
        };

        applyTheme(getTheme());
    </script>

    <script>
        const themes = ["system", "light", "dark"] as const;
        type Theme = (typeof themes)[number];

        const getTheme = (): Theme => {
            const saved = localStorage.getItem("theme") as Theme;
            return themes.includes(saved) ? saved : "system";
        };

        const updateIcons = (currentTheme: Theme) => {
            const lightIcon = document.getElementById("theme-icon-light");
            const darkIcon = document.getElementById("theme-icon-dark");
            const systemIcon = document.getElementById("theme-icon-system");

            lightIcon?.classList.toggle("hidden", currentTheme !== "light");
            darkIcon?.classList.toggle("hidden", currentTheme !== "dark");
            systemIcon?.classList.toggle("hidden", currentTheme !== "system");
        };

        const applyTheme = (theme: Theme) => {
            const isDark =
                theme === "dark" ||
                (theme === "system" &&
                    window.matchMedia("(prefers-color-scheme: dark)").matches);

            document.documentElement.classList.toggle("dark", isDark);
            updateIcons(theme);
        };

        const initThemeToggle = () => {
            const toggleBtn = document.getElementById("theme-toggle");
            let currentTheme = getTheme();

            updateIcons(currentTheme);

            toggleBtn?.addEventListener("click", () => {
                const nextIndex =
                    (themes.indexOf(currentTheme) + 1) % themes.length;
                currentTheme = themes[nextIndex];

                localStorage.setItem("theme", currentTheme);
                applyTheme(currentTheme);
            });

            window
                .matchMedia("(prefers-color-scheme: dark)")
                .addEventListener("change", () => {
                    if (getTheme() === "system") {
                        applyTheme("system");
                    }
                });
        };

        initThemeToggle();
        document.addEventListener("astro:after-swap", initThemeToggle);
    </script>
</Fragment>
