---
import { render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../i18n/utils";

import type { Lang } from "../../i18n/config";

interface Props {
  post: CollectionEntry<"blog">;
  lang?: string;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang as Lang);

const { title, createdAt, description, tags } = post.data;

const { Content } = await render(post);

const basePath = lang ? `/${lang}` : "";
const formattedDate = new Date(createdAt).toLocaleDateString(t("isoLocale"), {
  year: "numeric",
  month: "long",
  day: "numeric",
});

function createSummary(body: string, maxLength = 100) {
  return (
    body
      .replace(/---[\s\S]*?---/, "")
      .replace(/[#*`_~\[\]()\-+>!]/g, "")
      .replace(/\s+/g, " ")
      .trim()
      .substring(0, maxLength) + "..."
  );
}

const joinPath = (basePath: string, path: string) => {
  const cleanPath = `/${basePath}/${path}`.replace(/\/+/g, "/");
  return cleanPath;
};

const ogURL = new URL(
  joinPath(basePath, `/og/${post.id}.png`),
  Astro.url.origin,
);
---

<Layout title={`${title}`} lang={lang}>
  <Fragment slot="head">
    <meta property="og:description" content={createSummary(post.body ?? "")} />
    <meta property="og:image" content={ogURL.toString()} />
  </Fragment>
  <article class="space-y-8" data-pagefind-body>
    <header class="space-y-3 border-b border-dashed border-ink-light/20 dark:border-ink-dark/20 pb-6">
      <div class="flex items-center gap-4 text-sm opacity-70">
        <time datetime={createdAt.toISOString()} data-pagefind-ignore
          >{formattedDate}</time
        >
      </div>

      <h1
        class="text-3xl font-bold leading-tight text-ink-light dark:text-ink-dark"
        data-pagefind-weight="0.9"
      >
        {title}
      </h1>

      {
        description && (
          <p class="text-sm italic opacity-80" data-pagefind-weight="0.7">
            {description}
          </p>
        )
      }

      {
        tags && tags.length > 0 && (
          <div
            class="flex flex-wrap gap-2 pt-2 text-xs"
            data-pagefind-weight="0.5"
          >
            {tags.map((tag) => (
              <span class="border border-ink-light/30 dark:border-ink-dark/30 px-2 py-0.5 rounded-sm">
                #{tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <div
      class="prose prose-mono max-w-none text-ink-light dark:text-ink-dark
      prose-headings:font-bold prose-headings:text-ink-light dark:prose-headings:text-ink-dark prose-headings:border-b prose-headings:border-ink-light/10 dark:prose-headings:border-ink-dark/10 prose-headings:pb-1 dark:prose-strong:text-ink-dark
      prose-a:text-ink-light dark:prose-a:text-ink-dark prose-a:underline prose-a:decoration-dashed hover:prose-a:opacity-70
      dark:prose-code:text-ink-dark prose-code:bg-ink-light/5 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-ink-light/5 dark:prose-pre:bg-ink-dark/5 prose-pre:text-ink-light dark:prose-pre:text-ink-dark prose-pre:border prose-pre:border-ink-light/10 dark:prose-pre:border-ink-dark/10
      prose-blockquote:border-l-2 prose-blockquote:border-ink-light/40 dark:prose-blockquote:border-ink-dark/40 prose-blockquote:italic prose-blockquote:pl-4 dark:prose-blockquote:text-ink-dark
      prose-hr:border-dashed prose-hr:border-ink-light/20 dark:prose-hr:border-ink-dark/20 prose-kbd:text-ink-light dark:prose-kbd:text-ink-dark prose-kbd:border"
      data-pagefind-weight="1.0"
    >
      <Content />
    </div>

    <div
      class="pt-8 border-t border-dashed border-ink-light/10 dark:border-ink-dark/10"
      data-pagefind-ignore
    >
      <p class="text-sm font-bold mb-3 opacity-80">SHARE</p>
      <div class="flex flex-wrap gap-3 text-xs">
        <a
          href={`https://x.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="border border-ink-light/30 dark:border-ink-dark/30 px-3 py-1 rounded-sm hover:opacity-70"
        >
          X (Twitter)
        </a>

        <a
          href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="border border-ink-light/30 dark:border-ink-dark/30 px-3 py-1 rounded-sm hover:opacity-70"
        >
          Facebook
        </a>

        <a
          href={`https://b.hatena.ne.jp/entry/${Astro.url.href.replace(/^https?:\/\//, "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="border border-ink-light/30 dark:border-ink-dark/30 px-3 py-1 rounded-sm hover:opacity-70"
        >
          Hatena
        </a>

        <button
          id="share-copy-btn"
          class="border border-ink-light/30 dark:border-ink-dark/30 px-3 py-1 rounded-sm hover:opacity-70 cursor-pointer"
        >
          Copy Link
        </button>
      </div>
    </div>

    <script>
      const copyBtn = document.getElementById("share-copy-btn");
      if (copyBtn) {
        copyBtn.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(window.location.href);
            const originalText = copyBtn.textContent;
            copyBtn.textContent = "Copied!";
            setTimeout(() => {
              copyBtn.textContent = originalText;
            }, 2000);
          } catch (err) {
            console.error("Failed to copy: ", err);
          }
        });
      }
    </script>

    <footer
      class="pt-12 border-t border-dashed border-ink-light/20 dark:border-ink-dark/20"
      data-pagefind-ignore
    >
      <a
        href="/"
        class="text-sm hover:underline decoration-dashed underline-offset-4"
      >
        &lt;- {t("article.back_to_index")}
      </a>
    </footer>
  </article>
</Layout>

<style is:global>
@reference "../../styles/global.css"

:not(pre) > code {
  @apply bg-ink-light/5 px-1 py-0.5 rounded text-ink-dark;
}

:not(pre) > code::before,
:not(pre) > code::after {
  content: none;
}

.dark :not(pre) > code {
  @apply bg-ink-dark/5 text-ink-dark;
}
</style>
