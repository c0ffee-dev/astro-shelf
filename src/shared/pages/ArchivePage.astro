---
import { type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import type { Page } from 'astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';


interface Props {
  lang?: string;
  page: Page<CollectionEntry<'blog'>>;
}

const { page, lang } = Astro.props;
const t = useTranslations(lang as Lang);

const { data: posts } = page;
---

<Layout title={`Blog - Page ${page.currentPage}`} lang={lang}>
  <section class="space-y-8">
    <h1 class="text-2xl font-bold border-b border-ink-light/40 dark:border-ink-dark/40 w-fit pb-1">
      {t('archive.archive_page', page.currentPage.toString(), page.lastPage.toString())}
    </h1>

    <ul class="space-y-4">
      {posts.map((post) => {
        const { title, createdAt } = post.data;
        const dateString = new Date(createdAt).toISOString().split('T')[0];

        return (
          <li class="flex flex-col md:flex-row md:items-baseline justify-between gap-1 md:gap-4">
            <div class="flex items-baseline gap-2 min-w-0">
              <a href={`/articles/${post.id}`} class="text-base font-medium hover:underline decoration-dashed underline-offset-4 truncate text-ink-light dark:text-ink-dark">
                {title}
              </a>
            </div>
            <div class="hidden md:block flex-1 border-b border-dotted border-ink-light/20 dark:border-ink-dark/20 mx-2"></div>
            <time datetime={createdAt.toISOString()} class="text-sm opacity-60 shrink-0">
              {dateString}
            </time>
          </li>
        );
      })}
    </ul>

    <nav class="flex items-center justify-between border-t border-dashed border-ink-light/20 dark:border-ink-dark/20 pt-8 text-sm">
      <div>
        {page.url.prev ? (
          <a href={page.url.prev} class="hover:underline decoration-dashed underline-offset-4">
            &lt;&lt; {t('archive.nav.prev')}
          </a>
        ) : (
          <span class="opacity-30 cursor-not-allowed">&lt;&lt; {t('archive.nav.prev')}</span>
        )}
      </div>

      <div class="bg-ink-light/5 dark:bg-ink-dark/5 px-3 py-1 rounded-sm border border-ink-light/10 dark:border-ink-dark/10 text-xs">
        {page.currentPage} / {page.lastPage}
      </div>

      <div>
        {page.url.next ? (
          <a href={page.url.next} class="hover:underline decoration-dashed underline-offset-4">
            {t('archive.nav.next')} &gt;&gt;
          </a>
        ) : (
          <span class="opacity-30 cursor-not-allowed">{t('archive.nav.next')} &gt;&gt;</span>
        )}
      </div>
    </nav>
  </section>
</Layout>
