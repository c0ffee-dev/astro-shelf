{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "@vue/typescript-plugin",
        "location": "node_modules/@vue/typescript-plugin",
        "languages": ["vue"]
      }
    ]
  }
}
